<?xml version="1.0" ?>
<launch>
  <arg name="robot_ip" default="192.168.1.51"/>
  <arg name="load_gripper" default="true" />
  <!-- 速度/加速度缩放因子 (0.0 ~ 1.0)，值越小运动越慢越安全 -->
  <arg name="velocity_scaling" default="0.1" />
  <arg name="acceleration_scaling" default="0.1" />

  <include file="$(find franka_control)/launch/franka_control.launch">
    <arg name="robot_ip" value="$(arg robot_ip)" />
    <arg name="load_gripper" value="false" />
  </include>
  <include file="$(find panda_moveit_config)/launch/panda_moveit.launch">
    <arg name="load_gripper" value="false" />
  </include>
  <node name="move_to_start" pkg="franka_example_controllers" type="move_to_start.py" output="screen" required="true">
    <param name="velocity_scaling" value="$(arg velocity_scaling)" />
    <param name="acceleration_scaling" value="$(arg acceleration_scaling)" />
  </node>
</launch>
